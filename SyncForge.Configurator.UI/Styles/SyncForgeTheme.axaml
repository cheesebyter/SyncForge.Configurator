<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StyleInclude Source="avares://SyncForge.Configurator.UI/Styles/Tokens.axaml" />
  <StyleInclude Source="avares://SyncForge.Configurator.UI/Styles/Controls/Button.axaml" />
  <StyleInclude Source="avares://SyncForge.Configurator.UI/Styles/Controls/TextBox.axaml" />
  <StyleInclude Source="avares://SyncForge.Configurator.UI/Styles/Controls/ListBox.axaml" />
  <StyleInclude Source="avares://SyncForge.Configurator.UI/Styles/Controls/ComboBox.axaml" />
  <StyleInclude Source="avares://SyncForge.Configurator.UI/Styles/Controls/ScrollBar.axaml" />

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource SfBrush.Background}" />
    <Setter Property="Foreground" Value="{DynamicResource SfBrush.Text}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource SfBrush.Text}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource SfBrush.TextMuted}" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource SfBrush.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SfBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="Border.panel-subtle">
    <Setter Property="Background" Value="{DynamicResource SfBrush.SurfaceAlt}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SfBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="Border.statusbar">
    <Setter Property="Background" Value="{DynamicResource SfBrush.Neutral200}" />
    <Setter Property="Padding" Value="10" />
  </Style>

  <Style Selector="ProgressBar">
    <Setter Property="Foreground" Value="{DynamicResource SfBrush.Primary}" />
  </Style>
</Styles>
