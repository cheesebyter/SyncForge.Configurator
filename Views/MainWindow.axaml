<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SyncForge.Configurator.Views.MainWindow"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Title="SyncForge Configurator (R 0.2.0)">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" ColumnDefinitions="*">
    <Border Grid.Row="0" Padding="16" Background="{DynamicResource SfBrush.Neutral900}">
      <DockPanel LastChildFill="True">
        <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Left">
          <Button Classes="secondary" Content="New" Click="OnNewClick" />
          <Button Classes="secondary" Content="New Job Wizard" Click="OnNewJobWizardClick" />
          <Button Classes="secondary" Content="Open" Click="OnOpenClick" />
          <Button Classes="secondary" Content="Save" Click="OnSaveClick" />
          <Button Classes="secondary" Content="Save As" Click="OnSaveAsClick" />
          <Button Classes="primary" Content="Validate" Click="OnValidateClick" />
          <Button Classes="primary" Content="Preflight" Click="OnPreflightClick" />
          <Button Classes="primary" Content="Dry-Run" Click="OnDryRunClick" />
          <Button Classes="primary" Content="Run" Click="OnRunClick" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Padding="12" Background="{DynamicResource SfBrush.Neutral100}">
      <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Current File:" FontWeight="SemiBold" />
          <TextBlock Text="{Binding CurrentFileDisplayName}" />
          <TextBlock Text="{Binding UnsavedIndicator}" Foreground="{DynamicResource SfBrush.Warning}" FontWeight="Bold" />
          <CheckBox Content="Unsaved Prompt aus (Session)" IsChecked="{Binding SkipUnsavedChangesPromptInSession, Mode=TwoWay}" Margin="10,0,0,0" />
        </StackPanel>

        <Border Classes="panel"
                IsVisible="{Binding IsWizardVisible}"
                Padding="10"
                CornerRadius="6">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Classes="section-title" Text="New Job Wizard" />
              <TextBlock Classes="muted" Text="{Binding WizardStepText}" VerticalAlignment="Center" />
            </StackPanel>

            <Grid ColumnDefinitions="180,*,Auto" RowDefinitions="Auto">
              <TextBlock Grid.Column="0" Text="Starter Template" VerticalAlignment="Center" />
              <ComboBox Grid.Column="1"
                        Margin="0,0,8,0"
                        ItemsSource="{Binding JobTemplateOptions}"
                        SelectedItem="{Binding SelectedJobTemplate, Mode=TwoWay}" />
              <Button Grid.Column="2" Classes="secondary" Content="Apply Template" Click="OnApplyTemplateClick" />
            </Grid>

            <TextBlock IsVisible="{Binding IsWizardStep1}" Text="Step 1: Select source connector" FontWeight="SemiBold" />
            <ComboBox IsVisible="{Binding IsWizardStep1}"
                      ItemsSource="{Binding SourceConnectors}"
                      SelectedItem="{Binding WizardSourceConnector, Mode=TwoWay}" />

            <TextBlock IsVisible="{Binding IsWizardStep2}" Text="Step 2: Select target connector" FontWeight="SemiBold" />
            <ComboBox IsVisible="{Binding IsWizardStep2}"
                      ItemsSource="{Binding TargetConnectors}"
                      SelectedItem="{Binding WizardTargetConnector, Mode=TwoWay}" />

            <TextBlock IsVisible="{Binding IsWizardStep3}" Text="Step 3: Select strategy" FontWeight="SemiBold" />
            <Grid IsVisible="{Binding IsWizardStep3}" ColumnDefinitions="180,*" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode" VerticalAlignment="Center" />
              <ComboBox Grid.Row="0" Grid.Column="1"
                        ItemsSource="{Binding StrategyModeOptions}"
                        SelectedItem="{Binding WizardStrategyMode, Mode=TwoWay}" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Upsert Key Fields" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WizardUpsertKeys, Mode=TwoWay}" Watermark="id,email" />
            </Grid>

            <TextBlock IsVisible="{Binding IsWizardStep4}" Text="Step 4: Base parameters" FontWeight="SemiBold" />
            <Grid IsVisible="{Binding IsWizardStep4}" ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Job Name" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WizardJobName, Mode=TwoWay}" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Source Path/URL" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WizardSourcePath, Mode=TwoWay}" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Target Path/URL" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WizardTargetPath, Mode=TwoWay}" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="secondary" Content="Back" Click="OnWizardBackClick" IsEnabled="{Binding CanWizardGoBack}" />
              <Button Classes="secondary" Content="Next" Click="OnWizardNextClick" IsEnabled="{Binding CanWizardGoNext}" />
              <Button Classes="primary" Content="Finish" Click="OnWizardFinishClick" IsEnabled="{Binding CanWizardFinish}" />
              <Button Classes="secondary" Content="Cancel" Click="OnWizardCancelClick" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Classes="panel-subtle" Margin="12,8,12,0">
      <Grid ColumnDefinitions="2*,2*,2*,Auto" RowDefinitions="Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Plugin Directory" FontWeight="SemiBold" />
        <TextBlock Grid.Row="0" Grid.Column="1" Text="Source Connector" FontWeight="SemiBold" />
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Target Connector" FontWeight="SemiBold" />

        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,8,8,0" Text="{Binding PluginDirectory, Mode=TwoWay}" />
        <ComboBox Grid.Row="1" Grid.Column="1"
                  Margin="0,8,8,0"
                  ItemsSource="{Binding SourceConnectors}"
                  SelectedItem="{Binding SelectedSourceConnector, Mode=TwoWay}" />
        <ComboBox Grid.Row="1" Grid.Column="2"
                  Margin="0,8,8,0"
                  ItemsSource="{Binding TargetConnectors}"
                  SelectedItem="{Binding SelectedTargetConnector, Mode=TwoWay}" />
        <Button Grid.Row="1" Grid.Column="3" Classes="secondary" Margin="0,8,0,0" Content="Reload" Click="OnReloadConnectorsClick" MinWidth="88" />
      </Grid>
    </Border>

    <Grid Grid.Row="3" ColumnDefinitions="3*,2*" Margin="12">
      <Border Grid.Column="0" Classes="panel">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="170" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="170" />
          </Grid.RowDefinitions>

          <TextBlock Classes="section-title" Text="JSON Editor" />
          <TextBox Grid.Row="1"
                   Margin="0,6,0,0"
                   Text="{Binding JsonContent, Mode=TwoWay}"
                   AcceptsReturn="True"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   FontFamily="Consolas"
                   FontSize="13" />

          <TextBlock Grid.Row="2" Classes="muted" Margin="0,6,0,0" Text="{Binding JsonPreviewState}" />
          <TextBlock Grid.Row="3" Classes="section-title" Margin="0,6,0,0" Text="JSON Preview (Live)" />
          <TextBox Grid.Row="4"
                   Margin="0,6,0,0"
                   Text="{Binding JsonPreviewContent}"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   FontFamily="Consolas"
                   FontSize="13" />
        </Grid>
      </Border>

      <Border Grid.Column="1" Classes="panel" Margin="12,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="10">
           
            <Expander Header="Connector Configuration" IsExpanded="{Binding IsConnectorConfigExpanded, Mode=TwoWay}">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="section-title" Text="Source Settings" />
                <ListBox ItemsSource="{Binding SourceSettings}" MaxHeight="120">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="170,*">
                        <TextBlock Grid.Column="0" Text="{Binding Key}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay}" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Classes="section-title" Text="Target Settings" Margin="0,8,0,0" />
                <ListBox ItemsSource="{Binding TargetSettings}" MaxHeight="120">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="170,*">
                        <TextBlock Grid.Column="0" Text="{Binding Key}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay}" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Classes="section-title" Text="Source Preview Columns" Margin="0,8,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="secondary" Content="Load Source Preview" Click="OnLoadSourcePreviewClick" />
                </StackPanel>
                <Border BorderBrush="{DynamicResource SfBrush.Neutral200}" BorderThickness="1" CornerRadius="6" Padding="6" MaxHeight="80">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SourceColumnsPreview}" />
                  </ScrollViewer>
                </Border>

                <TextBlock Classes="section-title" Text="Mappings" Margin="0,8,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="secondary" Content="Add Mapping" Click="OnAddMappingClick" />
                  <Button Classes="danger" Content="Remove Selected" Click="OnRemoveMappingClick" />
                </StackPanel>
                <ListBox ItemsSource="{Binding MappingRows}"
                         SelectedItem="{Binding SelectedMappingRow, Mode=TwoWay}"
                         MaxHeight="150">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="*,*,Auto" Margin="0,2,0,2">
                        <TextBox Grid.Column="0" Text="{Binding SourceField, Mode=TwoWay}" Watermark="Source field" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding TargetField, Mode=TwoWay}" Watermark="Target field" Margin="0,0,6,0" />
                        <CheckBox Grid.Column="2" IsChecked="{Binding IsRequired, Mode=TwoWay}" VerticalAlignment="Center" Content="Required" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Expander>

            <Expander Header="Validation and Errors" IsExpanded="{Binding IsValidationExpanded, Mode=TwoWay}">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="section-title" Text="Validation Errors" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="secondary" Content="Go To Selected Error" Click="OnNavigateValidationErrorClick" />
                </StackPanel>
                <ListBox ItemsSource="{Binding ValidationErrors}"
                         SelectedItem="{Binding SelectedValidationError, Mode=TwoWay}"
                         MaxHeight="110" />

                <TextBlock Classes="section-title" Text="Preflight Findings" Margin="0,8,0,0" />
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding PreflightState}" Classes="muted" />
                  <Button Grid.Row="0" Grid.Column="1" Classes="secondary" Content="Export Preflight" Click="OnExportPreflightClick" Margin="8,0,0,0" />
                  <ListBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding PreflightFindings}" MaxHeight="120" Margin="0,6,0,0">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Rendered}" TextWrapping="Wrap" />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>

                <TextBlock Classes="section-title" Text="Error Details" Margin="0,8,0,0" />
                <TextBlock Classes="muted" Text="{Binding LastErrorSummary}" Foreground="{DynamicResource SfBrush.Danger}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="secondary" Content="Copy Error Details" Click="OnCopyErrorDetailsClick" IsEnabled="{Binding HasErrorDetails}" />
                </StackPanel>
                <TextBox Text="{Binding LastErrorDetails}"
                         IsReadOnly="True"
                         IsVisible="{Binding HasErrorDetails}"
                         AcceptsReturn="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Height="90"
                         FontFamily="Consolas"
                         FontSize="11" />
              </StackPanel>
            </Expander>

            <Expander Header="Logs and Diagnostics" IsExpanded="{Binding IsLogsExpanded, Mode=TwoWay}">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="section-title" Text="Log Viewer" />
                <Grid ColumnDefinitions="Auto,120,Auto,*,Auto" RowDefinitions="Auto">
                  <TextBlock Grid.Column="0" Text="Level" VerticalAlignment="Center" Margin="0,0,6,0" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding LogLevelOptions}"
                            SelectedItem="{Binding SelectedLogLevel, Mode=TwoWay}" />
                  <TextBlock Grid.Column="2" Text="Search" VerticalAlignment="Center" Margin="10,0,6,0" />
                  <TextBox Grid.Column="3" Text="{Binding LogSearchText, Mode=TwoWay}" Watermark="Filter logs..." />
                  <Button Grid.Column="4" Classes="secondary" Content="Export" Click="OnExportLogsClick" Margin="10,0,0,0" />
                </Grid>
                <ListBox ItemsSource="{Binding FilteredLogs}" MaxHeight="140" />

                <TextBlock Classes="section-title" Text="Dry-Run Logs" Margin="0,8,0,0" />
                <ListBox ItemsSource="{Binding DryRunLogs}" MaxHeight="120" />

                <TextBlock Classes="section-title" Text="Run Logs" Margin="0,8,0,0" />
                <ListBox ItemsSource="{Binding RunLogs}" MaxHeight="120" />
              </StackPanel>
            </Expander>

            <Expander Header="Summaries and Metadata" IsExpanded="{Binding IsSummaryExpanded, Mode=TwoWay}">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="section-title" Text="Dry-Run Summary (JSON)" />
                <TextBox Text="{Binding DryRunSummaryJson}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Height="100"
                         FontFamily="Consolas"
                         FontSize="12" />

                <TextBlock Classes="section-title" Text="Run Progress" Margin="0,8,0,0" />
                <ProgressBar IsVisible="{Binding IsRunInProgress}" IsIndeterminate="True" Height="8" />

                <TextBlock Classes="section-title" Text="Run Summary (JSON)" Margin="0,8,0,0" />
                <TextBox Text="{Binding RunSummaryJson}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Height="100"
                         FontFamily="Consolas"
                         FontSize="12" />

                <TextBlock Classes="section-title" Text="Connector Metadata" Margin="0,8,0,0" />
                <TextBox Text="{Binding ConnectorMetadata}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Height="100" />
              </StackPanel>
            </Expander>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <Border Grid.Row="4" Classes="statusbar">
      <TextBlock Text="{Binding StatusMessage}" />
    </Border>
  </Grid>
</Window>
